# Copy to `.env` — never commit `.env`. Do not paste real OAuth client_secret in tracked files.

# ── YouTube OAuth ─────────────────────────────────────────────
# Option A: path to GCP client_secret JSON
# YOUTUBE_CLIENT_SECRET_JSON=C:\Users\you\Downloads\client_secret_xxx.apps.googleusercontent.com.json

# Option B: client id + secret (fill only in `.env`; keep these commented or placeholders here)
# YOUTUBE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
# YOUTUBE_OAUTH_CLIENT_SECRET=

# Redirect URI — must match GCP OAuth client exactly
# YOUTUBE_OAUTH_REDIRECT_URI=http://localhost:8765/oauth2callback

# ── Gemini ────────────────────────────────────────────────────
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# ── Comment server ─────────────────────────────────────────────
# COMMENT_PORT=8766

# ── Proxy for Node → Google ───────────────────────────────────
# HTTPS_PROXY=http://127.0.0.1:9876
# HTTP_PROXY=http://127.0.0.1:9876
